# Example usage
# ---------------------------------------------------------------------

def generate_synthetic_prices(
    n_days: int = 1500,
    seed: int = 42,
) -> pd.DataFrame:
    """
    Generate synthetic multi-asset geometric price paths for demonstration.

    This is useful for testing the engine without external data sources.
    """
    rng = np.random.default_rng(seed)

    dates = pd.bdate_range("2020-01-01", periods=n_days)

    # Daily mean returns
    mu = np.array([0.0004, 0.0002, 0.0003])

    # Daily covariance matrix
    cov = np.array(
        [
            [0.00018, 0.00007, 0.00005],
            [0.00007, 0.00012, 0.00004],
            [0.00005, 0.00004, 0.00015],
        ]
    )

    simulated_log_returns = rng.multivariate_normal(mean=mu, cov=cov, size=n_days)
    log_price_paths = np.cumsum(simulated_log_returns, axis=0)
    prices = 100.0 * np.exp(log_price_paths)

    df = pd.DataFrame(
        prices,
        index=dates,
        columns=["Asset_A", "Asset_B", "Asset_C"],
    )
    return df


def main() -> None:
    # -----------------------------------------------------------------
    # Option 1: Replace this with your own data
    # -----------------------------------------------------------------
    # Example for real data:
    # prices = pd.read_csv("prices.csv", index_col=0, parse_dates=True)
    # weights = [0.50, 0.30, 0.20]

    # -----------------------------------------------------------------
    # Option 2: Synthetic demo data
    # -----------------------------------------------------------------
    prices = generate_synthetic_prices(n_days=1500)
    weights = [0.50, 0.30, 0.20]

    engine = PortfolioRiskEngine(
        prices=prices,
        weights=weights,
        return_type="log",
        rebalance="daily",
    )

    # In-sample risk summary
    report = engine.static_risk_report(alphas=(0.95, 0.99))
    print("\n=== STATIC RISK REPORT ===")
    print(report.round(6))

    # Rolling out-of-sample one-step-ahead risk forecasts
    rolling = engine.rolling_risk(
        window=250,
        alphas=(0.95, 0.99),
        include_historical=True,
        include_gaussian=True,
    )

    print("\n=== ROLLING FORECAST SAMPLE ===")
    print(rolling.tail().round(6))

    # Backtest 99% historical VaR
    hist_99_col = "historical_var_99"
    gauss_99_col = "gaussian_var_99"

    bt_hist_99 = engine.backtest(
        var_series=rolling[hist_99_col],
        alpha=0.99,
        model_name="Historical VaR 99%",
    )
    bt_gauss_99 = engine.backtest(
        var_series=rolling[gauss_99_col],
        alpha=0.99,
        model_name="Gaussian VaR 99%",
    )

    print("\n=== BACKTEST: HISTORICAL 99% ===")
    print(bt_hist_99.round(6))

    print("\n=== BACKTEST: GAUSSIAN 99% ===")
    print(bt_gauss_99.round(6))

    # Visual diagnostics
    engine.plot_return_distribution(alphas=(0.95, 0.99))
    engine.plot_backtest(
        var_series=rolling[hist_99_col],
        title="Historical 99% VaR Backtest",
    )
    engine.plot_backtest(
        var_series=rolling[gauss_99_col],
        title="Gaussian 99% VaR Backtest",
    )


if __name__ == "__main__":
    main()
